# Base URL of the search service (server/app.py).
#
#   development — leave EMPTY. vite.config.ts proxies /api to localhost:8080,
#                 so requests are same-origin and CORS never comes up.
#   production  — the Cloud Run Service URL, e.g.
#                 https://tmu-case-db-xxxxxxxxxx.northamerica-northeast2.run.app
#
# The GitHub Pages build reads this from .github/workflows/deploy.yml.
VITE_API_BASE=

# Set to "false" to fall back to the legacy in-browser index
# (public/data/textindex.json). Anything else, including unset, uses the API.
VITE_USE_API=
